# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=zenfocus
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=zenfocus

# Used by Prisma (points to the postgres service inside Docker)
DATABASE_URL=postgresql://zenfocus:change-me-in-production@postgres:5432/zenfocus

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# ─── Next.js ───────────────────────────────────────────────────────────────────
# Public: used by the browser to reach the API
NEXT_PUBLIC_API_URL=http://localhost:3001
# Internal: used by Next.js Route Handlers (server-side, inside Docker)
API_INTERNAL_URL=http://api:3001

# ─── Resend (transactional email) ──────────────────────────────────────────────
# Get an API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=ZenFocus <noreply@yourdomain.com>

# ─── App URL (used in email links) ────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Unsplash ──────────────────────────────────────────────────────────────────
# Optional — dashboard background images. Get a key at https://unsplash.com/developers
# Consumed by the `api` service; cached in Redis for 25h (never reaches the web container)
UNSPLASH_ACCESS_KEY=
