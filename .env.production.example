# Production environment template — copy to .env on the VPS and fill values.
#
#   cp .env.production.example .env
#
# Generate strong secrets with: openssl rand -hex 64

# ─── Image registry ───────────────────────────────────────────────────────────
# GitHub user/org that owns the GHCR images (must match `release.yml`).
GHCR_OWNER=your-github-username
# Image tag to deploy (commit SHA recommended; "latest" for the most recent build).
TAG=latest

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=zenfocus
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=zenfocus
# Must match POSTGRES_* above. Host is the docker service name "postgres".
DATABASE_URL=postgresql://zenfocus:replace-with-strong-password@postgres:5432/zenfocus

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT secrets ──────────────────────────────────────────────────────────────
# REQUIRED. At least 32 chars. Generate fresh values per environment.
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Public origin browsers use to reach the app (must be HTTPS in prod).
APP_URL=https://app.example.com
# Comma-separated allowed origins for CORS on the API.
CORS_ORIGIN=https://app.example.com
# Single origin allowed by the Socket.io gateway.
FRONTEND_URL=https://app.example.com
# Public API URL exposed to the browser (Nginx proxies /api → api:3001).
NEXT_PUBLIC_API_URL=https://app.example.com/api
# Internal URL used by Next.js Route Handlers (Docker network only).
API_INTERNAL_URL=http://api:3001

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=ZenFocus <noreply@yourdomain.com>

# ─── Unsplash (optional dashboard backgrounds) ────────────────────────────────
UNSPLASH_ACCESS_KEY=
